<?xml version="1.0" encoding="utf-8"?>

<robot name="scene">
    <link name="scene">
        <!-- in x, table edge to wooden plate edge is 0.303 on one side and .306 on the other -->
        <!-- in y table edge to wooden plate edge is 0.3025 on one side and .3065 on the other -->
        <visual>
            <!-- <origin rpy="-1.57079 0 1.57079" xyz="0.23008 0 -0.02858"/> -->
            <!-- drake has different coordinate frame convention and we need to remove the roll -->
            <origin rpy="0 0 1.57079" xyz="0.23008 0 -0.02858"/>
            <geometry>
                <mesh filename="table/table.gltf" scale="0.001 0.001 0.001"/>
            </geometry>
        </visual>
        <visual>
            <!-- <origin rpy="-1.57079 0 1.57079" xyz="-0.07669 0 -0.00953"/> -->
            <!-- drake has different coordinate frame convention and we need to remove the roll -->
            <origin rpy="0 0 1.57079" xyz="-0.07669 0 -0.00953"/>
            <geometry>
                <mesh filename="franka_mount/wooden_plate.gltf" scale="0.001 0.001 0.001"/>
            </geometry>
        </visual>
        <visual>
            <origin rpy="0 0 -1.57079" xyz="0 0 0"/>
            <geometry>
                <mesh filename="franka_mount/base_plate.obj"/>
            </geometry>
        </visual>
    </link>
</robot>