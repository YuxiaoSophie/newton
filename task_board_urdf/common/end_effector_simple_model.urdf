<?xml version="1.0"?>
<!-- Frames all align with the Franka's origin at configuration = 0. -->

<robot name="end_effector_simple">
  <material name="end_effector_simple_material">
    <color rgba="0.0 0.6 0.0 1.0" />
  </material>

  <link name="base_link" />

  <link name="end_effector_simple">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <mass value="0.057" />
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <cylinder radius="0.003" length="0.006" />
      </geometry>
      <material name="end_effector_simple_material" />
    </visual>
    <collision name="end_effector_simple_collision">
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <box size="0.01 0.015 0.01" />
      </geometry>
      <drake:proximity_properties>
        <drake:mu_static value="1" />
        <drake:mu_dynamic value="1" />
      </drake:proximity_properties>
    </collision>
  </link>

  <link name="end_effector_simple_fake_x" />

  <link name="end_effector_simple_fake_y" />

  <link name="end_effector_simple_fake_rx" />

  <link name="end_effector_simple_fake_ry" />

  <link name="end_effector_simple_fake_rz" />

  <joint name="end_effector_simple_to_base_x" type="prismatic">
    <parent link="base_link" />
    <child link="end_effector_simple_fake_x" />
    <axis xyz="1 0 0" />
  </joint>
  <joint name="end_effector_simple_to_base_y" type="prismatic">
    <parent link="end_effector_simple_fake_x" />
    <child link="end_effector_simple_fake_y" />
    <axis xyz="0 1 0" />
  </joint>
  <joint name="end_effector_simple_to_base_z" type="prismatic">
    <parent link="end_effector_simple_fake_y" />
    <child link="end_effector_simple_fake_rx" />
    <axis xyz="0 0 1" />
  </joint>

  <joint name="end_effector_simple_roll" type="revolute">
    <parent link="end_effector_simple_fake_rx" />
    <child link="end_effector_simple_fake_ry" />
    <axis xyz="1 0 0" />
    <limit lower="-3.14159" upper="3.14159" effort="1" velocity="10" />
  </joint>
  <joint name="end_effector_simple_pitch" type="revolute">
    <parent link="end_effector_simple_fake_ry" />
    <child link="end_effector_simple_fake_rz" />
    <axis xyz="0 1 0" />
    <limit lower="-3.14159" upper="3.14159" effort="1" velocity="10" />
  </joint>
  <joint name="end_effector_simple_yaw" type="revolute">
    <parent link="end_effector_simple_fake_rz" />
    <child link="end_effector_simple" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14159" upper="3.14159" effort="1" velocity="10" />
  </joint>

  <transmission name="end_effector_simple_to_base_trans_x"
    type="SimpleTransmission">
    <actuator name="end_effector_simple_to_base_act_x" />
    <joint name="end_effector_simple_to_base_x" />
    <mechanicalReduction>1</mechanicalReduction>
  </transmission>

  <transmission name="end_effector_simple_to_base_trans_y"
    type="SimpleTransmission">
    <actuator name="end_effector_simple_to_base_act_y" />
    <joint name="end_effector_simple_to_base_y" />
    <mechanicalReduction>1</mechanicalReduction>
  </transmission>

  <transmission name="end_effector_simple_to_base_trans_z"
    type="SimpleTransmission">
    <actuator name="end_effector_simple_to_base_act_z" />
    <joint name="end_effector_simple_to_base_z" />
    <mechanicalReduction>1</mechanicalReduction>
  </transmission>

  <transmission name="end_effector_simple_roll_trans" type="SimpleTransmission">
    <actuator name="end_effector_simple_roll_act" />
    <joint name="end_effector_simple_roll" />
    <mechanicalReduction>1</mechanicalReduction>
  </transmission>

  <transmission name="end_effector_simple_pitch_trans" type="SimpleTransmission">
    <actuator name="end_effector_simple_pitch_act" />
    <joint name="end_effector_simple_pitch" />
    <mechanicalReduction>1</mechanicalReduction>
  </transmission>

  <transmission name="end_effector_simple_yaw_trans" type="SimpleTransmission">
    <actuator name="end_effector_simple_yaw_act" />
    <joint name="end_effector_simple_yaw" />
    <mechanicalReduction>1</mechanicalReduction>
  </transmission>
</robot>